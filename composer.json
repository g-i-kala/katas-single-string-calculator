{
  "name": "karo_ej/katas-tmp",
  "description": "Katas Template",
  "version": "1.0.0",
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "g-i-kala",
      "email": "5star@wp.pl"
    }
  ],
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "phpstan/phpstan": "^2.1",
    "rector/rector": "^2.4",
    "laravel/pint": "^1.29",
    "approvals/approval-tests": "dev-Main",
    "symplify/easy-coding-standard": "^11.1"
  },
  "scripts": {
    "tests": "phpunit",
    "test-coverage": "phpunit --coverage-html build/coverage",
    "check-cs": "ecs check",
    "fix-cs": "ecs check --fix",
    "phpstan": "phpstan analyse --ansi",
    "rector": "rector process",
    "format": "pint"
  }
}
